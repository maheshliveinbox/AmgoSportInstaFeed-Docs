      "id": "63d016b7-fda6-4da8-a3d2-ef48a0d8fa52",
      "name": "Filter Products with Images",
      "type": "n8n-nodes-base.filter",
      "typeVersion": 2.2,
      "position": [1088, -576]
    },
    {
      "parameters": {
        "jsCode": "const product = $input.first().json;\nconst storeHandle = $env.SHOPIFY_STORE_DOMAIN?.replace('.myshopify.com','') || 'amgosports';\n\n// Determine category from product_type or tags\nconst tagLower = (product.tags || '').toLowerCase();\nconst typeLower = (product.product_type || '').toLowerCase();\nlet category = 'Other';\nif (typeLower.includes('bat') || tagLower.includes('bat')) category = 'Bats';\nelse if (typeLower.includes('glove') || tagLower.includes('glove')) category = 'Gloves';\nelse if (typeLower.includes('pad') || tagLower.includes('pad')) category = 'Protection';\nelse if (typeLower.includes('helmet') || tagLower.includes('helmet')) category = 'Helmets';\nelse if (typeLower.includes('ball') || tagLower.includes('ball')) category = 'Balls';\nelse if (typeLower.includes('bag') || tagLower.includes('bag')) category = 'Bags';\nelse if (typeLower.includes('cloth') || tagLower.includes('cloth')) category = 'Clothing';\n\n// Get first image\nconst imageUrl = product.images?.[0]?.src || '';\n\n// Get lowest price variant\nconst variants = product.variants || [];\nconst prices = variants.map(v => parseFloat(v.price)).filter(p => !isNaN(p));\nconst price = prices.length > 0 ? Math.min(...prices).toFixed(2) : '0.00';\n\n// Check stock\nconst inStock = variants.some(v => v.inventory_quantity > 0 || v.inventory_management === null);\n\nreturn [{\n  json: {\n    product_id: String(product.id),\n    title: product.title,\n    vendor: product.vendor,\n    price: price,\n    image_url: imageUrl,\n    product_url: `https://amgosports.com.au/products/${product.handle}`,\n    category: category,\n    in_stock: inStock ? 'TRUE' : 'FALSE',\n    synced_at: new Date().toISOString(),\n    featured: 'FALSE'\n  }\n}];"
      },
