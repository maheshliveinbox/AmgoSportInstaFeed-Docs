    {
      "parameters": {
        "jsCode": "const today = new Date().toISOString().split('T')[0];\nconst apiData = $input.first().json;\n\nif (!apiData?.data || !Array.isArray(apiData.data)) {\n  return [{ json: { date: today, is_match_day: false, match_title: '', teams: '', venue: '', start_time: '', notes: 'CricAPI error or no data' } }];\n}\n\nconst RELEVANT_TEAMS = ['australia', 'aus', 'nsw', 'queensland', 'victoria', 'south australia', 'western australia', 'tasmania', 'sydney', 'melbourne', 'brisbane', 'perth', 'adelaide', 'hobart'];\nconst RELEVANT_SERIES = ['bbl', 'big bash', 'sheffield shield', 'test', 'odi', 'australia', 't20i', 'aus'];\nconst RELEVANT_VENUES = ['australia', 'sydney', 'melbourne', 'brisbane', 'perth', 'adelaide', 'hobart', 'scg', 'mcg', 'gabba', 'waca', 'manuka', 'cairns'];\n\nconst isAustralian = (match) => {\n  const searchText = [match.name || '', match.matchType || '', match.series || '', match.venue || '', ...(match.teams || [])].join(' ').toLowerCase();\n  return RELEVANT_TEAMS.some(t => searchText.includes(t)) || RELEVANT_SERIES.some(s => searchText.includes(s)) || RELEVANT_VENUES.some(v => searchText.includes(v));\n};\n\nconst currentOrUpcoming = apiData.data.filter(m => !m.matchEnded && isAustralian(m));\n\nif (currentOrUpcoming.length === 0) {\n  return [{ json: { date: today, is_match_day: false, match_title: '', teams: '', venue: '', start_time: '', notes: `No Australian matches found. Total matches checked: ${apiData.data.length}` } }];\n}\n\nconst match = currentOrUpcoming[0];\nconst teams = (match.teams || []).join(' vs ');\nconst startTime = match.dateTimeGMT ? new Date(match.dateTimeGMT).toLocaleString('en-AU', { timeZone: 'Australia/Sydney', hour: '2-digit', minute: '2-digit' }) : 'TBC';\n\nreturn [{ json: { date: today, is_match_day: true, match_title: match.name || 'Australian Cricket Match', teams: teams, venue: match.venue || 'Australia', start_time: startTime + ' AEST', notes: `Match type: ${match.matchType || 'unknown'} | Status: ${match.status || 'upcoming'}` } }];"
      },
