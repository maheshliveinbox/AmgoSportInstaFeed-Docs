    {
      "parameters": {
        "jsCode": "const posts = $input.first().json.data;\nif (!posts || posts.length === 0) return [];\nreturn posts.map(p => ({ json: { postId: p.postId } }));"
      },
      "id": "node-extract-posts",
      "name": "Extract Stale Posts",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        832,
        144
      ]
    },
    {
      "parameters": {
        "method": "PATCH",
        "url": "={{ $('Fetch Workflow Config').item.json.data.appUrl }}/api/posts/{{ $json.postId }}",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "status",
              "value": "EXPIRED"
            }
          ]
        },
        "options": {}
      },
